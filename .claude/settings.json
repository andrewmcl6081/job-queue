{
    "$schema": "https://json.schemastore.org/claude-code-settings.json",
    "permissions": {
        "defaultMode": "acceptEdits",
        "allow": [
            "Bash(git status)",
            "Bash(git diff *)",
            "Bash(go test ./...)",
            "Bash(go vet ./...)",
            "Bash(gofmt -w *)",
            "Bash(make *)",
            "Bash(docker compose *)"
        ],
        "deny": [
            "Read(./.env)",
            "Bash(./.env.*)",
            "Bash(./secrets/**)"
        ]
    },
    "sandbox": {
        "enabled": true,
        "autoAllowBashIfSandboxed": true,
        "excludedCommands": [
            "docker *"
        ],
        "network": {
            "allowedDomains": [
                "github.com",
                "proxy.golang.org",
                "sum.golang.org"
            ]
        }
    },
    "autoMemoryEnabled": true,
    "model": "sonnet",
    "effortLevel": "high"
}
